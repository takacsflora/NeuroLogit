    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File (with Workspace PYTHONPATH)",
            "type": "debugpy",
            "request": "launch",
            // "module": '',
            "env": {"PYTHONPATH": "${workspaceFolder}${pathSeparator}${env:PYTHONPATH}"},
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}